# Web core runtime
DATABASE_URL=file:./storage/sqlite/db.sqlite
APP_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me

# Optional admin whitelist used for bootstrap/admin access.
# Supported forms:
# - empty
# - one email: admin@example.com
# - multiple emails: admin@example.com,ops@example.com
WEB_ADMIN_EMAILS=admin@example.com
# Optional per-user bot creation hard limit.
# - empty or 0: unlimited
# - positive integer: max bots each user can create
WEB_USER_BOT_LIMIT=0

INSTANCES_ROOT=./storage/instances

# Supervisor runtime
# Allowed values:
# - remote: inject each user's sandbox-runtime pool URL/key into FastAgent child
# - disabled: run FastAgent without sandbox args
FASTAGENT_SANDBOX_MODE=remote
RECONCILE_INTERVAL_MS=2000

# Per-user sandbox-runtime pool defaults.
# For host-local development, keep SRT_SERVICE_HOST=localhost if the
# sandbox-runtime manager runs on the host network.
SRT_SERVICE_HOST=localhost
SRT_POOL_CONFIG_FILE=./storage/sandbox-runtime-private/srt-pools.json
SRT_POOL_STATUS_FILE=./storage/sandbox-runtime-private/srt-pool-status.json
SRT_WORKSPACE_MAP_DIR=./storage/sandbox-runtime-private/workspace-map
SRT_DEFAULT_POOL_SIZE=3
SRT_DEFAULT_MIN_READY_PROCESSES=1
SRT_DEFAULT_SESSION_TIMEOUT_MS=600000
SRT_DEFAULT_MAX_CONCURRENT_INIT=1
SRT_DEFAULT_HEALTH_CHECK_INTERVAL_MS=60000
SRT_DEFAULT_PORT_RANGE_WIDTH=100
SRT_PORT_BASE=31000
SRT_PROXY_PORT_BASE=9100
SRT_WORKSPACE_BASE_ROOT=./storage/sandbox-runtime-user-workspaces
SRT_DEFAULT_DENIED_DOMAINS=
SRT_DEFAULT_ALLOW_READ=
SRT_DEFAULT_ALLOW_WRITE=/tmp
SRT_DEFAULT_DENY_READ=/etc/passwd,/etc/shadow,/root,~/.ssh,~/.aws
SRT_DEFAULT_DENY_WRITE=.env,~/.ssh,~/.aws

# Optional override when you do not want to use the repo-local
# apps/supervisor/node_modules/.bin/fastagent binary.
# FASTAGENT_BINARY_PATH=/absolute/path/to/fastagent
